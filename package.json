{
  "name": "inventory-flow-remake",
  "version": "1.0.0",
  "description": "Inventory management remake with HTML/CSS/JS, Node.js, FastAPI, SQLite, JWT, and REST APIs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "web": "nodemon server.js",
    "api": "python -m uvicorn backend.main:app --reload --host 127.0.0.1 --port 8000",
    "dev": "npm run web"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
